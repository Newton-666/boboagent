{
  "name": "bobo-desktop",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "start": "electron ."
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  },
  "build": {
    "appId": "com.bobo.agent",
    "productName": "Bobo",
    "mac": {
      "category": "public.app-category.productivity",
      "target": "dmg"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "../../bobo_tui_gateway",
        "to": "bobo-backend/bobo_tui_gateway",
        "filter": ["**/*"]
      },
      {
        "from": "../../core",
        "to": "bobo-backend/core",
        "filter": ["**/*"]
      },
      {
        "from": "../../tools",
        "to": "bobo-backend/tools",
        "filter": ["**/*"]
      },
      {
        "from": "../../config.py",
        "to": "bobo-backend/config.py"
      },
      {
        "from": "../../pyproject.toml",
        "to": "bobo-backend/pyproject.toml"
      }
    ]
  }
}
